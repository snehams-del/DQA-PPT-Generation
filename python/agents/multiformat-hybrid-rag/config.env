# =============================================================================
# GCP Configuration
# =============================================================================
PROJECT_ID=my-project
PROJECT_NAME=multiformat-hybrid-rag
DEFAULT_REGION=us-central1

# =============================================================================
# GCS — Source of Truth
# =============================================================================
GCS_BUCKET=${PROJECT_ID}-rag-docs
GCS_PREFIX=documents/

# =============================================================================
# BigQuery — Metadata & Preprocessing
# =============================================================================
BQ_DATASET=rag_pipeline
BQ_OBJECT_TABLE=gcs_objects
BQ_PREPROCESSED_TABLE=preprocessed
BQ_CHUNKS_TABLE=chunks
BQ_GCS_CONNECTION_ID=rag-gcs-connection

# =============================================================================
# Vector Search 2.0
# =============================================================================
VS_COLLECTION_ID=${PROJECT_NAME}-collection
VS_DOCUMENTS_COLLECTION_ID=${PROJECT_NAME}-documents
VS_EMBEDDING_MODEL=gemini-embedding-001
VS_EMBEDDING_DIMS=3072
VS_BATCH_SIZE=250

# =============================================================================
# Gemini Models
# =============================================================================
AGENT_GEMINI_MODEL=gemini-2.5-flash
MCP_TOOL_GEMINI_MODEL=gemini-2.5-flash-lite
MARKDOWN_CONVERTER_GEMINI_MODEL=gemini-3-flash-preview
CONTEXTUAL_CHUNKING_GEMINI_MODEL=gemini-2.5-flash-lite
RELEVANCE_GEMINI_MODEL=gemini-2.5-flash-lite

# =============================================================================
# Vertex AI Pipelines
# =============================================================================
SERVICE_ACCOUNT=${PROJECT_NAME}-rag@${PROJECT_ID}.iam.gserviceaccount.com
PIPELINE_ROOT=gs://${PROJECT_ID}-${PROJECT_NAME}-pipeline/pipeline-root
PIPELINE_IMAGE=${DEFAULT_REGION}-docker.pkg.dev/${PROJECT_ID}/${PROJECT_NAME}-pipeline/data-pipeline:latest
PREPROCESS_SERVICE_IMAGE=${DEFAULT_REGION}-docker.pkg.dev/${PROJECT_ID}/${PROJECT_NAME}-pipeline/preprocess-service:latest
CHUNK_INDEX_SERVICE_IMAGE=${DEFAULT_REGION}-docker.pkg.dev/${PROJECT_ID}/${PROJECT_NAME}-pipeline/chunk-index-service:latest

# =============================================================================
# Pipeline Scheduling
# =============================================================================
PIPELINE_CRON="0 2 * * *"

# =============================================================================
# Search
# =============================================================================
VS_SEMANTIC_WEIGHT=0.7

# =============================================================================
# Chunking
# =============================================================================
CHUNK_SIZE=1500
CHUNK_OVERLAP=300
