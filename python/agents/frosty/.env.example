
# Snowflake credentials
SNOWFLAKE_USER_NAME="<YOUR_SNOWFLAKE_USERNAME>"
SNOWFLAKE_USER_PASSWORD="<YOUR_SNOWFLAKE_PASSWORD>"
SNOWFLAKE_ACCOUNT_IDENTIFIER="<YOUR_SNOWFLAKE_ACCOUNT_IDENTIFIER>"
#SNOWFLAKE_AUTHENTICATOR="" # Optional: "externalbrowser" (passkey) or "username_password_mfa" (Duo/TOTP). Leave unset for standard password auth.
#SNOWFLAKE_ROLE="" # Optional: Snowflake role to use for the session, e.g. "SVC_AI_BOT_ROLE"
#SNOWFLAKE_WAREHOUSE="" # Optional: Snowflake warehouse to use, e.g. "SVC_AI_BOT_WH"
#SNOWFLAKE_DATABASE="" # Optional: Default database for the session, e.g. "ANALYTICS"

# Application config
APP_USER_NAME="<YOUR_APP_USER_NAME>" # This is the name that will be used in the app, e.g. in the UI and for logging. It can be different from the Snowflake username.
APP_USER_ID="<YOUR_APP_USER_ID>" # This is an optional unique identifier for the user, e.g. an email address or UUID. It can be used for tracking and analytics purposes.
APP_NAME="<YOUR_APP_NAME>" # This is the name of your application, e.g. 'Frosty Analytics'. It can be used for logging and analytics purposes.

# ── Model provider ────────────────────────────────────────────────────────────
# Set to "google" , "anthropic", or "openai"
MODEL_PROVIDER="anthropic"

# ── Google models (used when MODEL_PROVIDER=google) ───────────────────────────
GOOGLE_API_KEY="sk-gp-api03-..." # Your Google API key with access to Gemini models
MODEL_PRIMARY="<YOUR_PRIMARY_MODEL>" # e.g. "gemini-2.5-flash"
MODEL_THINKING="<YOUR_THINKING_MODEL>" # Required for Gemini — used for reasoning-heavy tasks. e.g. "gemini-2.5-pro-preview-03-25"

# ── Anthropic models (used when MODEL_PROVIDER=anthropic) ─────────────────────
ANTHROPIC_API_KEY="sk-anthropic-..." # Your Anthropic API key with access to Claude models
MODEL_PRIMARY="YOUR_PRIMARY_MODEL" # e.g. 'anthropic/claude-3-5-sonnet-20241022'
# Note: MODEL_THINKING is not used for Anthropic — Claude handles reasoning internally.

# ── OpenAI models (used when MODEL_PROVIDER=openai) ───────────────────────────
OPENAI_API_KEY="sk-..." # Your OpenAI API key with access to GPT models
MODEL_PRIMARY="YOUR_PRIMARY_MODEL" # e.g. 'openai/gpt-4o-mini'
# Note: MODEL_THINKING is not used for OpenAI — reasoning is handled by the model internally.

# ── OpenTelemetry / Grafana Cloud ─────────────────────────────────────────────
# Set OTEL_ENABLED=true to export traces, metrics, and logs to Grafana Cloud.
# Leave as false (default) for zero overhead — no OTel code is invoked.
OTEL_ENABLED=false
OTEL_SERVICE_NAME="frosty_open_source"
OTEL_EXPORTER_OTLP_ENDPOINT="https://otlp-gateway-<region>.grafana.net/otlp"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic%20<your-base64-token>"  # from Grafana Cloud → Stack → OpenTelemetry

# ── Moltbook ───────────────────────────────────────────────────────────────────
#MOLTBOOK_API_KEY="" # Optional: API key for your agent's Moltbook profile (moltbook.com)

# ── Debug ──────────────────────────────────────────────────────────────────────
#FROSTY_DEBUG=1           # Set to 1 to print agent thinking, tool calls, and payloads
#USE_SKILLS=true          # Set to false to disable SKILL.md reference injection — agents use model knowledge only (fewer tokens, slightly faster)
