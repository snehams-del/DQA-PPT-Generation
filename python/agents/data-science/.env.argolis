# Copy as .env file and fill your values below
# Run ./update_dotenv_example.sh to update .env-example from your .env file.

# Choose Model Backend: 0 -> ML Dev, 1 -> Vertex
GOOGLE_GENAI_USE_VERTEXAI=1

# ML Dev backend config. Fill if using Ml Dev backend.
GOOGLE_API_KEY=YOUR_VALUE_HERE

# Vertex backend config
GOOGLE_CLOUD_PROJECT=dsagent-dev
GOOGLE_CLOUD_LOCATION=us-central1

# SQLGen method
BQ_NL2SQL_METHOD = "BASELINE" # BASELINE or CHASE

# Set up BigQuery Agent
BQ_COMPUTE_PROJECT_ID=dsagent-bq-compute
BQ_DATA_PROJECT_ID=dsagent-bq-data
BQ_DATASET_ID="cymbal_flights_dataset"

# Set up AlloyDB Agent
ALLOYDB_PROJECT_ID=dsagent-alloydb
ALLOYDB_DATABASE=flights_dataset
ALLOYDB_SCHEMA_NAME=public

# Set up RAG Corpus for BQML Agent
#BQML_RAG_CORPUS_NAME="projects/354931194622/locations/us-central1/ragCorpora/6917529027641081856"
BQML_RAG_CORPUS_NAME='projects/817007630178/locations/us-central1/ragCorpora/2305843009213693952'

# Set up Code Interpreter, if it exists. Else leave empty
# Either '' or 'projects/{GOOGLE_CLOUD_PROJECT}/locations/us-central1/extensions/{EXTENSION_ID}'
CODE_INTERPRETER_EXTENSION_NAME='projects/817007630178/locations/us-central1/extensions/4015215803765882880'

# Models used in Agents
ROOT_AGENT_MODEL='gemini-2.5-flash'
ANALYTICS_AGENT_MODEL='gemini-2.5-flash'
BIGQUERY_AGENT_MODEL='gemini-2.5-flash'
BASELINE_NL2SQL_MODEL='gemini-2.5-flash'
CHASE_NL2SQL_MODEL='gemini-2.5-flash'
BQML_AGENT_MODEL='gemini-2.5-flash'
ALLOYDB_AGENT_MODEL='gemini-2.5-flash'
