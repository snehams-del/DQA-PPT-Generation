# Gemini API key — get one at https://aistudio.google.com/app/apikey.
GOOGLE_API_KEY=

# OpenRegistry MCP endpoint. Defaults to the public hosted server with the
# anonymous tier (no signup needed). For higher rate-limits or fan-out,
# complete the OAuth flow at openregistry.sophymarine.com/account and pass
# the bearer token via OPENREGISTRY_TOKEN.
OPENREGISTRY_MCP_URL=https://openregistry.sophymarine.com/mcp
# OPENREGISTRY_TOKEN=
