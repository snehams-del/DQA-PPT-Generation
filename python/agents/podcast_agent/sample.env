GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
# Optional: Model location if different from cloud location (e.g. "global")
MODEL_GOOGLE_CLOUD_LOCATION="us-central1"

# Optional: TTS Configuration
# Defaults to gemini-2.5-pro-tts if not set
TTS_MODEL_NAME="gemini-2.5-pro-tts"
# Defaults to GOOGLE_CLOUD_LOCATION if not set
TTS_LOCATION="us-central1"
