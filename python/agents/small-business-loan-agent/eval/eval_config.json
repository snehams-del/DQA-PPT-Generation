{
  "criteria": {
    "rubric_based_tool_use_quality_v1": {
      "threshold": 0.8,
      "judge_model_options": {
        "judge_model": "gemini-3.1-pro-preview",
        "num_samples": 1
      },
      "rubrics": [
        {
          "rubric_id": "status_first",
          "rubric_content": {
            "text_property": "check_process_status is called before any agent tools on the initial request. Post-approval continuation turns do not require check_process_status."
          }
        },
        {
          "rubric_id": "extraction_before_underwriting",
          "rubric_content": {
            "text_property": "DocumentExtractionAgent is called before UnderwritingAgent."
          }
        },
        {
          "rubric_id": "underwriting_before_pricing",
          "rubric_content": {
            "text_property": "UnderwritingAgent is called before PricingAgent."
          }
        },
        {
          "rubric_id": "approval_required",
          "rubric_content": {
            "text_property": "LoanDecisionAgent is only called after user approval."
          }
        },
        {
          "rubric_id": "pricing_before_decision",
          "rubric_content": {
            "text_property": "PricingAgent is called before LoanDecisionAgent."
          }
        }
      ]
    },
    "rubric_based_final_response_quality_v1": {
      "threshold": 0.8,
      "judge_model_options": {
        "judge_model": "gemini-3.1-pro-preview",
        "num_samples": 1
      },
      "rubrics": [
        {
          "rubric_id": "loan_summary_completeness",
          "rubric_content": {
            "text_property": "When presenting loan results, the response includes key details such as business name, owner name, loan amount, annual revenue, eligibility status, risk tier, interest rate, and monthly payment."
          }
        },
        {
          "rubric_id": "clear_next_step",
          "rubric_content": {
            "text_property": "The response clearly indicates the next step: either asking for user approval (yes/no), confirming process completion, reporting current status, or requesting missing information to proceed."
          }
        },
        {
          "rubric_id": "error_handling_clarity",
          "rubric_content": {
            "text_property": "When data is missing or an error occurs, the response clearly identifies what is missing or wrong."
          }
        }
      ]
    },
    "final_response_match_v2": 0.7
  }
}
