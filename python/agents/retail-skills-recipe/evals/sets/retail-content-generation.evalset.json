{
  "skill": "retail-content-generation",
  "version": "1.0",
  "description": "Evaluation cases for the retail content generation skill -- covers descriptions, SEO, brand voice, translations, and A/B testing.",
  "uses_catalog": true,
  "eval_cases": [
    {
      "eval_id": "product_description",
      "query": "Generate a product description for a wireless keyboard",
      "assertions": [
        {"type": "response_not_empty"},
        {"type": "skill_covers", "topic": "description"},
        {"type": "response_min_length", "value": 50}
      ]
    },
    {
      "eval_id": "seo_title",
      "query": "Write an SEO-optimized title for a running shoe",
      "assertions": [
        {"type": "skill_covers", "topic": "seo"},
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 20}
      ]
    },
    {
      "eval_id": "brand_voice",
      "query": "How do I make the content match our luxury brand tone?",
      "assertions": [
        {"type": "skill_covers", "topic": "brand"},
        {"type": "skill_covers", "topic": "tone"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "multi_language",
      "query": "Generate a product description in Spanish and French",
      "assertions": [
        {"type": "skill_covers", "topic": "translation"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "ab_variants",
      "query": "Generate 3 different descriptions to A/B test for this product",
      "assertions": [
        {"type": "skill_covers", "topic": "a/b"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "meta_description",
      "query": "Write a meta description for a product page",
      "assertions": [
        {"type": "skill_covers", "topic": "meta"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "marketing_copy",
      "query": "Create a promotional email body for our summer sale",
      "assertions": [
        {"type": "skill_covers", "topic": "marketing"},
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 40}
      ]
    },
    {
      "eval_id": "gemini_model_mentioned",
      "query": "What AI model powers the content generation?",
      "assertions": [
        {"type": "skill_covers", "topic": "gemini"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "dependency_check",
      "query": "What do I need set up before using content generation?",
      "assertions": [
        {"type": "skill_covers", "topic": "retail-product-search"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "factuality_guidance",
      "query": "How do I prevent the model from making up product specs that don't exist?",
      "assertions": [
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 30}
      ]
    }
  ]
}
