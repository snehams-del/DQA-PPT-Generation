# The Google Cloud Project ID where services are hosted
GCP_PROJECT_ID=your-gcp-project-id

# The Google Cloud region for services (e.g., global, us-central1)
GCP_REGION=your-gcp-region

# The name of the Firestore database to use
FIRESTORE_DB=contracts

# Optional: Set this to use a local Firestore emulator
#FIRESTORE_EMULATOR_HOST=localhost:8080

# The ID of the Google Drive folder containing contracts
DRIVE_FOLDER_ID=your-drive-folder-id

# The webhook URL for sending Slack notifications
SLACK_WEBHOOK_URL=your-slack-webhook-url

# Optional: The Gemini model version to use for extraction
#GEMINI_MODEL_ID=gemini-1.5-flash

# The Cloud Storage bucket name for storing processed contracts
GCS_BUCKET=your-gcs-bucket-name
