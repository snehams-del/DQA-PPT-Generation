%% Billing Agent Architecture
%% Google Cloud Platform Style

graph TB
    subgraph "Billing Agent"
        Agent[💳 Billing Agent<br/>Model: Gemini 2.5 Flash<br/>Callback: auto_save_to_memory_explicit]
        Note[⚠️ NOTE: Refunds processed<br/>via refund_workflow only<br/>NOT available directly]
    end

    subgraph "Tools"
        T0[PreloadMemoryTool<br/>Load user memories]
        T1[get_invoice<br/>Get by invoice ID]
        T2[get_invoice_by_order_id<br/>Get by order ID]
        T3[get_my_invoices<br/>All invoices for authenticated user]
        T4[check_payment_status<br/>Payment status for order]
        T5[get_my_payments<br/>All payments for authenticated user]
        T6[get_refundable_items<br/>Check what items can be refunded]
        T7[get_acceptable_refund_reasons<br/>List valid refund reasons]
    end

    subgraph "Data Sources"
        Firestore[(Firestore<br/>Invoices/Payments)]
        Memory[(Memory Bank)]
    end

    Agent --> T0
    Agent --> T1
    Agent --> T2
    Agent --> T3
    Agent --> T4
    Agent --> T5
    Agent --> T6
    Agent --> T7

    T0 --> Memory
    T1 --> Firestore
    T2 --> Firestore
    T3 --> Firestore
    T4 --> Firestore
    T5 --> Firestore
    T6 --> Firestore

    style Agent fill:#FBBC04,stroke:#F29900,color:#000,stroke-width:3px
    style Note fill:#EA4335,stroke:#C5221F,color:#fff,stroke-width:2px
    style T0 fill:#9334E6,stroke:#7627BB,color:#fff
    style T1 fill:#4285F4,stroke:#1967D2,color:#fff
    style T2 fill:#4285F4,stroke:#1967D2,color:#fff
    style T3 fill:#4285F4,stroke:#1967D2,color:#fff
    style T4 fill:#4285F4,stroke:#1967D2,color:#fff
    style T5 fill:#4285F4,stroke:#1967D2,color:#fff
    style T6 fill:#4285F4,stroke:#1967D2,color:#fff
    style T7 fill:#4285F4,stroke:#1967D2,color:#fff
    style Firestore fill:#FF6F00,stroke:#E65100,color:#fff
    style Memory fill:#9334E6,stroke:#7627BB,color:#fff
