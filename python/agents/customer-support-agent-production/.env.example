# Google Cloud Configuration
# ==========================
# Your GCP project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# GitHub owner (username or organisation) — used by setup-cloud-build
GITHUB_OWNER=your-github-username

# GCP region for services (us-central1, us-east1, etc.)
GOOGLE_CLOUD_LOCATION=us-central1

# GCS bucket for staging deployments (with gs:// prefix)
GOOGLE_CLOUD_STORAGE_BUCKET=gs://your-bucket-name

# Agent Engine Configuration
# ===========================
# Display name used to find-or-create the Agent Engine.
# To switch to a new agent engine, change this name — deploy.py will create a new one
# and overwrite the agent-engine-resource-name secret so Cloud Run picks it up.
AGENT_ENGINE_DISPLAY_NAME=customer-support-multiagent

# Resource name from Agent Engine deployment (set automatically by deploy.py on first create)
# Format: projects/PROJECT_ID/locations/LOCATION/reasoningEngines/ENGINE_ID
AGENT_ENGINE_RESOURCE_NAME=projects/123/locations/us-central1/reasoningEngines/456

# Optional: Use Vertex AI instead of direct Gemini API
GOOGLE_GENAI_USE_VERTEXAI=1

# Optional: Firestore database name (default: (default))
FIRESTORE_DATABASE=customer-support-db

# Model Armor Configuration (optional)
# ======================================
# Set MODEL_ARMOR_ENABLED=true to screen prompts and responses through
# Google Cloud Model Armor. Requires a template created in the console
# or via setup_model_armor.sh.
MODEL_ARMOR_ENABLED=false
# Full resource name: projects/{project}/locations/{location}/templates/{template_id}
MODEL_ARMOR_TEMPLATE_ID=
# Enforcement mode for floor settings (INSPECT_ONLY | INSPECT_AND_BLOCK)
MODEL_ARMOR_MODE=INSPECT_AND_BLOCK
