#!/usr/bin/env bash
# vs — Vertical Skills CLI (lightweight)
#
# This script is for contributors working in the repo. Its jobs:
#
#   1. List available skills                →  vs list
#   2. Run programmatic quality checks      →  vs eval <skill>
#   3. Self-improving loop on SKILL.md      →  vs improve <skill>
#
# To install a skill into your agent project, use:
#   npx install-vertical-skill <skill> [--target gemini|claude]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$SCRIPT_DIR/skills"

bold=$'\033[1m'; green=$'\033[32m'; cyan=$'\033[36m'; red=$'\033[31m'; nc=$'\033[0m'

usage() {
    cat <<EOF
${bold}vs${nc} — Vertical Skills CLI (contributor tools)

${bold}Usage:${nc}
  vs list                          List available skills
  vs eval <skill> [--verbose]      Run the skill's evalset
  vs improve <skill> [--rounds N]  Self-improving loop on the SKILL.md

${bold}Examples:${nc}
  vs list
  vs eval retail-virtual-tryon
  vs improve retail-virtual-tryon --rounds 3

${bold}To install a skill:${nc} ${cyan}npx install-vertical-skill <skill>${nc}
EOF
}

die() { echo "${red}Error:${nc} $*" >&2; exit 1; }

require_skill() {
    [[ -d "$SKILLS_DIR/$1" ]] || die "skill '$1' not found. Try 'vs list'."
}

# ── vs list ──────────────────────────────────────────────────────────────────

list_skills() {
    echo "${bold}Available skills:${nc}"
    echo ""
    for d in "$SKILLS_DIR"/*/; do
        name=$(basename "$d")
        [[ -f "$d/SKILL.md" ]] || continue
        # Pull the description: line from frontmatter (handles >- folded form)
        desc=$(awk '/^description:/{found=1; sub(/^description: *>?-? */, ""); if (length($0)>0) print; next} found && /^  /{sub(/^  +/, ""); printf " %s", $0; next} found{exit}' "$d/SKILL.md" | head -1)
        echo "  ${green}$name${nc}"
        [[ -n "$desc" ]] && echo "    $desc"
    done
    echo ""
    echo "Install a skill with: ${cyan}npx install-vertical-skill <skill>${nc}"
}

# ── vs eval ──────────────────────────────────────────────────────────────────

run_eval() {
    local skill="${1:-}"
    [[ -n "$skill" ]] || die "skill name required. Try 'vs list'."
    require_skill "$skill"
    shift
    local project_id="${GOOGLE_CLOUD_PROJECT:-}"
    [[ -n "$project_id" ]] || read -r -p "GCP Project ID: " project_id </dev/tty

    python "$SCRIPT_DIR/evals/run.py" --skill "$skill" --project-id "$project_id" "$@"
}

# ── vs improve ───────────────────────────────────────────────────────────────

run_improve() {
    local skill="${1:-}"
    [[ -n "$skill" ]] || die "skill name required. Try 'vs list'."
    require_skill "$skill"
    shift
    local project_id="${GOOGLE_CLOUD_PROJECT:-}"
    [[ -n "$project_id" ]] || read -r -p "GCP Project ID: " project_id </dev/tty

    PYTHONPATH="$SCRIPT_DIR" python "$SCRIPT_DIR/evals/improve.py" --skill "$skill" --project-id "$project_id" "$@"
}

# ── main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
    list)            list_skills ;;
    eval)            shift; run_eval "$@" ;;
    improve)         shift; run_improve "$@" ;;
    -h|--help|"")    usage ;;
    gemini|claude)
        echo "${red}Error:${nc} 'vs $1' has been removed." >&2
        echo "Install skills with: ${cyan}npx install-vertical-skill <skill> --target $1${nc}" >&2
        exit 1
        ;;
    *)
        echo "${red}Error:${nc} unknown command: $1" >&2
        usage
        exit 1
        ;;
esac
