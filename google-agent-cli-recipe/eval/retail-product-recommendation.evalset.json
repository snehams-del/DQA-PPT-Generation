{
  "skill": "retail-product-recommendation",
  "version": "1.0",
  "description": "Evaluation cases for the retail product recommendation skill — covers recommendation types, cold start, relevance, and configuration.",
  "eval_cases": [
    {
      "eval_id": "basic_recommendation",
      "query": "Show me products similar to the one I just viewed",
      "assertions": [
        {"type": "response_not_empty"},
        {"type": "skill_covers", "topic": "recommendation"},
        {"type": "response_min_length", "value": 30}
      ]
    },
    {
      "eval_id": "you_might_also_like",
      "query": "What other products might I like based on my cart?",
      "assertions": [
        {"type": "response_not_empty"},
        {"type": "skill_covers", "topic": "collaborative"},
        {"type": "contains_keyword", "value": "product"}
      ]
    },
    {
      "eval_id": "cold_start_handling",
      "query": "A new user just signed up. We have no purchase history for them.",
      "assertions": [
        {"type": "skill_covers", "topic": "cold start"},
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 40}
      ]
    },
    {
      "eval_id": "collaborative_vs_content",
      "query": "What is the difference between collaborative filtering and content-based recommendations?",
      "assertions": [
        {"type": "skill_covers", "topic": "collaborative"},
        {"type": "skill_covers", "topic": "content-based"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "vertex_ai_recommendations",
      "query": "Can I use Google's managed recommendation engine instead of building my own?",
      "assertions": [
        {"type": "skill_covers", "topic": "vertex ai"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "llm_recommendations",
      "query": "I want the agent to reason about why it recommends a product, not just pattern-match",
      "assertions": [
        {"type": "skill_covers", "topic": "llm"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "placement_options",
      "query": "Where should I show recommendations — product page, cart, or homepage?",
      "assertions": [
        {"type": "skill_covers", "topic": "placement"},
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 30}
      ]
    },
    {
      "eval_id": "user_events_data",
      "query": "Do I need user event data to use recommendations?",
      "assertions": [
        {"type": "skill_covers", "topic": "user event"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "dependency_check",
      "query": "What do I need before setting up recommendations?",
      "assertions": [
        {"type": "skill_covers", "topic": "retail-product-search"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "diversity_handling",
      "query": "The recommendations all look the same. How do I add diversity?",
      "assertions": [
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 30}
      ]
    }
  ]
}
