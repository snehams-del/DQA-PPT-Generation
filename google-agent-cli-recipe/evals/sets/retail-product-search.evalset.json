{
  "skill": "retail-product-search",
  "version": "1.0",
  "description": "Evaluation cases for the retail product search skill -- covers search quality, edge cases, and agent behavior.",
  "uses_catalog": true,
  "catalog_brands": ["Sony", "Generic", "Anker", "Keychron", "BenQ"],
  "eval_cases": [
    {
      "eval_id": "headphones_under_200",
      "query": "headphones under 200",
      "assertions": [
        {"type": "contains_product", "field": "name", "value": "Wireless Headphones"},
        {"type": "price_under", "value": 200},
        {"type": "tool_called", "tool": "retrieve_docs"},
        {"type": "no_hallucination", "forbidden": ["Bose", "AirPods", "Sennheiser"]}
      ]
    },
    {
      "eval_id": "cheapest_item",
      "query": "what is the cheapest product you have",
      "assertions": [
        {"type": "tool_called", "tool": "retrieve_docs"},
        {"type": "mentions_price", "value": true},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "keyboard_search",
      "query": "mechanical keyboard for coding",
      "assertions": [
        {"type": "contains_product", "field": "name", "value": "Mechanical Keyboard"},
        {"type": "mentions_field", "field": "brand"},
        {"type": "mentions_field", "field": "price"},
        {"type": "tool_called", "tool": "retrieve_docs"}
      ]
    },
    {
      "eval_id": "category_filter",
      "query": "show me all audio products",
      "assertions": [
        {"type": "tool_called", "tool": "retrieve_docs"},
        {"type": "contains_product", "field": "category", "value": "Audio"},
        {"type": "no_hallucination", "forbidden": ["speaker system", "turntable"]}
      ]
    },
    {
      "eval_id": "brand_search",
      "query": "do you have any Sony products",
      "assertions": [
        {"type": "tool_called", "tool": "retrieve_docs"},
        {"type": "contains_product", "field": "brand", "value": "Sony"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "no_results_handling",
      "query": "do you have any cars for sale",
      "assertions": [
        {"type": "tool_called", "tool": "retrieve_docs"},
        {"type": "graceful_no_results"}
      ]
    },
    {
      "eval_id": "comparison_query",
      "query": "compare the keyboard and the headphones",
      "assertions": [
        {"type": "tool_called", "tool": "retrieve_docs"},
        {"type": "mentions_field", "field": "price"},
        {"type": "response_min_length", "value": 50}
      ]
    },
    {
      "eval_id": "price_range",
      "query": "products between 50 and 150 dollars",
      "assertions": [
        {"type": "tool_called", "tool": "retrieve_docs"},
        {"type": "mentions_price", "value": true},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "vague_query_handling",
      "query": "I need something for my desk",
      "assertions": [
        {"type": "tool_called", "tool": "retrieve_docs"},
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 30}
      ]
    },
    {
      "eval_id": "skill_covers_vector_search",
      "query": "how do you search for products",
      "assertions": [
        {"type": "skill_covers", "topic": "vector search"},
        {"type": "skill_covers", "topic": "bigquery"},
        {"type": "response_not_empty"}
      ]
    }
  ]
}
