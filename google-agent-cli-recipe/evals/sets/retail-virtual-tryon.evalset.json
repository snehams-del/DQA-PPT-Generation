{
  "skill": "retail-virtual-tryon",
  "version": "1.0",
  "description": "Evaluation cases for the retail virtual try-on skill — covers model selection, safety, categories, privacy, and edge cases.",
  "eval_cases": [
    {
      "eval_id": "basic_clothing_tryon",
      "query": "I want to try on this jacket before buying it",
      "assertions": [
        {"type": "response_not_empty"},
        {"type": "skill_covers", "topic": "clothing"},
        {"type": "response_min_length", "value": 30}
      ]
    },
    {
      "eval_id": "eyewear_tryon",
      "query": "Can I see how these sunglasses look on my face?",
      "assertions": [
        {"type": "response_not_empty"},
        {"type": "skill_covers", "topic": "eyewear"},
        {"type": "contains_keyword", "value": "face"}
      ]
    },
    {
      "eval_id": "default_model_is_vto",
      "query": "Which model should I use for clothing try-on?",
      "assertions": [
        {"type": "skill_covers", "topic": "virtual-try-on-001"},
        {"type": "contains_keyword", "value": "vto"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "model_selection_flash",
      "query": "What is the fastest Gemini option for try-on?",
      "assertions": [
        {"type": "skill_covers", "topic": "gemini-2.5-flash-image"},
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 30}
      ]
    },
    {
      "eval_id": "model_selection_pro",
      "query": "I need the highest quality try-on images for editorial brand work",
      "assertions": [
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "vto_vs_gemini_choice",
      "query": "When should I pick the dedicated VTO model versus the Gemini image models?",
      "assertions": [
        {"type": "skill_covers", "topic": "virtual-try-on-001"},
        {"type": "skill_covers", "topic": "text prompt"},
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 50}
      ]
    },
    {
      "eval_id": "privacy_handling",
      "query": "Will my photo be saved after the try-on?",
      "assertions": [
        {"type": "skill_covers", "topic": "privacy"},
        {"type": "contains_keyword", "value": "delete"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "safety_filter_config",
      "query": "How do I configure the safety filter for an adult fashion brand?",
      "assertions": [
        {"type": "skill_covers", "topic": "safety"},
        {"type": "skill_covers", "topic": "block"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "unsupported_category",
      "query": "Can I try on this sofa to see if it fits my living room?",
      "assertions": [
        {"type": "graceful_no_results"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "latency_expectation",
      "query": "How long does a try-on take?",
      "assertions": [
        {"type": "skill_covers", "topic": "latency"},
        {"type": "skill_covers", "topic": "second"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "photo_quality_guidance",
      "query": "My try-on image doesn't look right. The product looks off.",
      "assertions": [
        {"type": "gotcha_mentioned", "term": "photo quality"},
        {"type": "response_not_empty"},
        {"type": "response_min_length", "value": 40}
      ]
    },
    {
      "eval_id": "footwear_tryon",
      "query": "Can I try on shoes?",
      "assertions": [
        {"type": "skill_covers", "topic": "footwear"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "quota_gotcha",
      "query": "We're hitting rate limit errors from the image generation API",
      "assertions": [
        {"type": "gotcha_mentioned", "term": "quota"},
        {"type": "response_not_empty"}
      ]
    },
    {
      "eval_id": "dependency_check",
      "query": "Do I need anything set up before using virtual try-on?",
      "assertions": [
        {"type": "skill_covers", "topic": "retail-product-search"},
        {"type": "contains_keyword", "value": "prerequisite"},
        {"type": "response_not_empty"}
      ]
    }
  ]
}
